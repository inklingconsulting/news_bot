# --- Copy this file to ".env" and fill in the two required secrets ---

# REQUIRED: Anthropic API key (get one at https://console.anthropic.com/ -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED: Telegram bot token (message @BotFather on Telegram, /newbot, copy the token)
TELEGRAM_BOT_TOKEN=123456:ABC-...

# REQUIRED: the chat the daily brief is sent to. This is a NUMBER (e.g. 123456789),
# NOT your bot's username. To get it: start the bot, message it in Telegram with
# /start, then send /chatid — it replies with the number to paste here.
TELEGRAM_CHAT_ID=

# --- Optional settings (sensible defaults shown) ---

# Which Claude model curates the news. Opus 4.8 is the default (best quality).
# For lower cost, use: claude-sonnet-5
MODEL=claude-opus-4-8

# When the daily brief is sent, in 24h local time.
TIMEZONE=America/New_York
BRIEF_HOUR=7
BRIEF_MINUTE=0
